graph TD
    A["JSONL + Images Root"] -->|"Byte-offset Seek"| B["ObjectDetectionDataset"]
    B -->|"Augment + Letterbox"| C["Dataset getitem"]
    C -->|"collate_fn"| D["DataLoader Batch"]
    D -->|"Pin Memory + H2D Transfer"| E["GPU Batch"]
    E -->|"AMP (FP16/BF16)"| F["NMSFreeDetector Forward"]
    F -->|"Classification + Regression Logits"| G["DetectionLoss"]
    G -->|"TaskAligned Assigner (Pixel Space)"| H["Positive Masks + Soft Targets"]
    H -->|"Grid Coordinate Scaling"| I["CIoU + DFL + BCE Loss"]
    I -->|"Weighted Sum"| J["Total Loss"]
    J -->|"GradScaler Backward"| K["Gradient Computation"]
    K -->|"GradScaler Unscale"| L["Unscaled Gradients"]
    L -->|"Gradient Logging"| M["TensorBoard Logger"]
    M -->|"Gradient Clipping (max_norm = 10.0)"| N["Clipped Gradients"]
    N -->|"Optimizer Step"| O["Weight Update"]
    O -->|"GradScaler Update"| P["Scaler Update"]
    P -->|"Scheduler Step"| Q["Cosine LR Scheduler"]
    Q -->|"EMA Update"| R["EMA Weights"]
    R -->|"Validation Interval"| S["Validation Loop"]
    S -->|"Best Validation Loss"| T["Save Checkpoint"]