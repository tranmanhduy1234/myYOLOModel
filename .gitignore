# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine to prevent git tracking.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a script / tool, it may be ignored.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally tracked in version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally tracked in version control.
#pdm.lock

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

